<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ─────────────────────────────────────────── -->

    <!-- Internet access (API calls) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Camera (QR scanning) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- GPS / Location (driver tracking) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Background location for GPS tracking while app is in background -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Flashlight/torch for QR scanner torch toggle -->
    <uses-permission android:name="android.permission.FLASHLIGHT" />

    <!-- Vibration for scan feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock (keep GPS running) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── Hardware Features ──────────────────────────────────── -->

    <!-- Camera is required (QR scanning) -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <!-- Autofocus preferred but not mandatory -->
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <!-- GPS is required (driver tracking) -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="true" />

    <application
        android:label="CloudNext Fleet"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Specifies an Android theme to apply to this Activity -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link support for cloudnext:// scheme (QR payloads) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="cloudnext" />
            </intent-filter>
        </activity>

        <!-- Required by flutter_local_notifications if used in future -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- FileProvider for sharing QR images if needed -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

    <!-- Required for Android 12+ (API 31+) if scheduling exact alarms -->
    <!-- Uncomment if needed:
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    -->

</manifest>
